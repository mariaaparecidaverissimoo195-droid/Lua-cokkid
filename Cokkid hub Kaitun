-- Função para atualizar stats
local function updateStats()
    while task.wait(2) do
        pcall(function()
            local lvl = player.Data.Level.Value
            local race = player.Data.Race.Value
            local fruit = "Nenhuma"
            local cdk = "❌"
            -- Verifica fruta equipada
            if player.Character then
                for _, tool in ipairs(player.Character:GetChildren()) do
                    if tool:IsA("Tool") and tool.Name:find("Fruit") then
                        fruit = tool.Name
                        break
                    end
                end
            end
            -- Verifica se tem CDK no inventário
            local inv = ReplicatedStorage.Remotes.CommF_:InvokeServer("getInventory")
            if type(inv) == "table" then
                for _, v in ipairs(inv) do
                    if v.Name == "Cursed Dual Katana" then
                        cdk = "✅"
                        break
                    end
                end
            end
            statsLabel.Text = string.format("Nível: %d\nRaça: %s\nFruta: %s\nCDK: %s", lvl, race, fruit, cdk)
        end)
    end
end
task.spawn(updateStats)

-- Função de teleporte suave (tween)
local function tweenTo(cframe)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local dist = (cframe.Position - hrp.Position).Magnitude
    local speed = dist < 100 and 50 or dist < 400 and 400 or dist < 1000 and 300 or 300
    local tween = TweenService:Create(hrp, TweenInfo.new(dist/speed, Enum.EasingStyle.Linear), {CFrame = cframe})
    tween:Play()
    tween.Completed:Wait()
end

-- Função para pegar quest e matar mobs
local function doQuest(questName, questLv, mobName, questPos, mobPos)
    if player.PlayerGui.Main.Quest.Visible then
        local questTitle = player.PlayerGui.Main.Quest.Container.QuestTitle.Title.Text
        if questTitle:find(mobName) then
            -- Mata mobs
            while task.wait() do
                local mob = workspace.Enemies:FindFirstChild(mobName)
                if mob and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                    tweenTo(mob.HumanoidRootPart.CFrame * CFrame.new(0, 20, 0))
                    -- Ataca
                    if player.Character and player.Character:FindFirstChildOfClass("Tool") then
                        local args = { [1] = mob.HumanoidRootPart, [2] = { [1] = mob } }
                        game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer(unpack(args))
                    end
                else
                    break
                end
            end
        else
            ReplicatedStorage.Remotes.CommF_:InvokeServer("AbandonQuest")
        end
    else
        tweenTo(questPos)
        task.wait(0.5)
        ReplicatedStorage.Remotes.CommF_:InvokeServer("StartQuest", questName, questLv)
    end
end

