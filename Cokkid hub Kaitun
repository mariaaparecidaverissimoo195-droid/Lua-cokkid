-- Auto Godhuman
local function autoGodhumanFunction()
    if not autoGodhuman then return end
    statusLabel.Text = "Status: Auto Godhuman"
    -- Verifica se já tem
    local inv = ReplicatedStorage.Remotes.CommF_:InvokeServer("getInventory")
    for _, v in ipairs(inv) do if v.Name == "Godhuman" then return end end

    -- Farm de materiais (simplificado)
    local needed = {
        {"Fish Tail", 20, "Fishman Warrior", CFrame.new(60946, 48, 1525)},
        {"Magma Ore", 20, "Magma Ninja", CFrame.new(-5466, 57, -5837)},
        {"Mystic Droplet", 10, "Sea Soldier", CFrame.new(-3115, 63, -9808)},
        {"Dragon Scale", 10, "Dragon Crew Warrior", CFrame.new(6241, 51, -1243)}
    }

    for _, item in ipairs(needed) do
        local name, count, mob, pos = item[1], item[2], item[3], item[4]
        local has = 0
        for _, v in ipairs(inv) do if v.Name == name then has = v.Count end end
        if has < count then
            -- Vai para o local e farma
            repeat
                tweenTo(pos)
                task.wait(1)
                local enemy = workspace.Enemies:FindFirstChild(mob)
                if enemy and enemy.Humanoid.Health > 0 then
                    tweenTo(enemy.HumanoidRootPart.CFrame * CFrame.new(0, 20, 0))
                    -- ataque
                end
            until has >= count
        end
    end

    -- Compra Godhuman
    if world == "Third" then
        tweenTo(CFrame.new(-13775, 334, -9881))
        task.wait(1)
        ReplicatedStorage.Remotes.CommF_:InvokeServer("BuyGodhuman")
    end
end

-- Auto Race V2/V3
local function autoRaceFunction()
    if not autoRaceV2 and not autoRaceV3 then return end
    statusLabel.Text = "Status: Auto Race"
    local race = player.Data.Race.Value
    if race:find("Human") then
        if autoRaceV2 then
            -- Evo V1 (se necessário)
            if ReplicatedStorage.Remotes.CommF_:InvokeServer("Alchemist", "1") ~= -2 then
                ReplicatedStorage.Remotes.CommF_:InvokeServer("Alchemist", "2")
            end
        end
        if autoRaceV3 then
            -- Evo V2 (Human)
            if ReplicatedStorage.Remotes.CommF_:InvokeServer("Wenlocktoad", "1") ~= 0 then
                ReplicatedStorage.Remotes.CommF_:InvokeServer("Wenlocktoad", "2")
                -- Matar bosses: Orbitus, Jeremy, Diamond
                local bosses = {"Orbitus", "Jeremy", "Diamond"}
                for _, bossName in ipairs(bosses) do
                    local boss = workspace.Enemies:FindFirstChild(bossName) or ReplicatedStorage:FindFirstChild(bossName)
                    if boss then
                        repeat
                            tweenTo(boss.HumanoidRootPart.CFrame * CFrame.new(0, 30, 0))
                            task.wait()
                        until not boss.Parent or boss.Humanoid.Health <= 0
                    end
                end
                ReplicatedStorage.Remotes.CommF_:InvokeServer("Wenlocktoad", "3")
            end
        end
    elseif race:find("Fishman") then
        if autoRaceV3 then
            -- Fishman V3
            if ReplicatedStorage.Remotes.CommF_:InvokeServer("Wenlocktoad", "1") ~= 0 then
                ReplicatedStorage.Remotes.CommF_:InvokeServer("Wenlocktoad", "2")
                -- Precisa de Sea Beast
                -- (simplificado)
            end
        end
    end
end

