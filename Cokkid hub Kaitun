-- Auto hop em servidores com baixa população (função Hop)
local function Hop()
    require(ReplicatedStorage.Notification).new("<Color=Red>cookid hub:<Color=/> Wait " .. TimeHop .. "s hop server"):Display()
    task.wait(TimeHopServer)
    require(ReplicatedStorage.Notification).new("<Color=Red>cookid hub: Hop!<Color=/>"):Display()
    local ids = {}
    local cursor = ""
    local function fetch()
        local url = 'https://games.roblox.com/v1/games/' .. placeId .. '/servers/Public?limit=100'
        if cursor ~= "" then url = url .. '&cursor=' .. cursor end
        local data = game:HttpGet(url)
        local decoded = HttpService:JSONDecode(data)
        cursor = decoded.nextPageCursor or ""
        return decoded.data
    end
    repeat
        local servers = fetch()
        for _, v in ipairs(servers) do
            if v.playing < v.maxPlayers and v.id ~= game.JobId then
                table.insert(ids, v.id)
            end
        end
        task.wait()
    until #ids > 0 or cursor == ""
    if #ids > 0 then
        local target = ids[math.random(1, #ids)]
        game:GetService("TeleportService"):TeleportToPlaceInstance(placeId, target, player)
    end
end

