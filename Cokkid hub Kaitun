local function SyncItems()
    local current = {}
    local inv = ReplicatedStorage.Remotes.CommF_:InvokeServer("getInventory")
    if type(inv) ~= "table" then return end
    for _, v in pairs(inv) do
        if type(v) == "table" and v.Name then
            current[v.Name] = true
            if not shownItems[v.Name] then
                local lbl = Instance.new("TextLabel")
                lbl.BackgroundTransparency = 1
                lbl.Size = UDim2.new(1,-6,0,18)
                lbl.Font = Enum.Font.GothamBold
                lbl.TextSize = 10
                lbl.TextColor3 = Color3.fromRGB(255,255,255)
                lbl.Text = v.Name
                lbl.Parent = scroll
                shownItems[v.Name] = lbl
            end
        end
    end
    for name, lbl in pairs(shownItems) do
        if not current[name] then
            lbl:Destroy()
            shownItems[name] = nil
        end
    end
    scroll.CanvasSize = UDim2.new(0,0,0, layout.AbsoluteContentSize.Y + 6)
end

