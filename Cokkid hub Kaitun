local function GetRaceVersion()
    local currentRace = player.Data.Race.Value
    local baseRace = string.gsub(currentRace, "%s+%(.+%)", "")
    local success, titles = pcall(function()
        return ReplicatedStorage.Remotes.CommF_:InvokeServer("getTitles")
    end)
    local maxVersion = 1
    if success and type(titles) == "table" then
        for _, t in pairs(titles) do
            if type(t) == "table" and t.Name then
                local raceData = raceMap[t.Name]
                if raceData and raceData.Race == baseRace and raceData.Version > maxVersion then
                    maxVersion = raceData.Version
                end
            end
        end
    end
    return baseRace, maxVersion
end

local fruit_collected = {}

local function GetInventoryItems()
    local success, inv = pcall(function()
        return ReplicatedStorage.Remotes.CommF_:InvokeServer("getInventory")
    end)
    if not success or type(inv) ~= "table" then return "None" end
    local items = {}
    for _, v in pairs(inv) do
        if type(v) == "table" and v.Name then
            table.insert(items, v.Name)
        end
    end
    table.sort(items)
    local maxItems = 15
    local displayed = {}
    if #items > maxItems then
        for i = 1, maxItems do displayed[i] = items[i] end
    else
        displayed = items
    end
    if #displayed == 0 then return "None" end
    return table.concat(displayed, ",\n")
end

local function GetFruitInfo()
    local fruitList = {
        "Rocket-Rocket","Spin-Spin","Blade-Blade","Spring-Spring","Bomb-Bomb",
        "Smoke-Smoke","Spike-Spike","Flame-Flame","Ice-Ice","Sand-Sand",
        "Dark-Dark","Eagle-Eagle","Diamond-Diamond","Light-Light","Rubber-Rubber",
        "Ghost-Ghost","Magma-Magma","Quake-Quake","Buddha-Buddha","Love-Love",
        "Creation-Creation","Spider-Spider","Sound-Sound","Phoenix-Phoenix",
        "Portal-Portal","Lightning-Lightning","Pain-Pain","Blizzard-Blizzard",
        "Gravity-Gravity","Mammoth-Mammoth","T-Rex-T-Rex","Dough-Dough",
        "Shadow-Shadow","Venom-Venom","Gas-Gas","Spirit-Spirit","Tiger-Tiger",
        "Yeti-Yeti","Kitsune-Kitsune","Control-Control","Dragon-Dragon"
    }
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, fruit in ipairs(fruitList) do
            local f = backpack:FindFirstChild(fruit)
            if f and f:FindFirstChild("Level") then
                return fruit:gsub("%-.*","") .. " [" .. f.Level.Value .. "]"
            end
        end
    end
    local character = player.Character
    if character then
        for _, fruit in ipairs(fruitList) do
            local f = character:FindFirstChild(fruit)
            if f and f:FindFirstChild("Level") then
                return fruit:gsub("%-.*","") .. " [" .. f.Level.Value .. "]"
            end
        end
    end
    return "None"
end

local function GetOwnedMelee()
    local meleeList = {}
    local checks = {
        {cmd = "BuyBlackLeg", name = "Dark Step"},
        {cmd = "BuyFishmanKarate", name = "Fishman Karate"},
        {cmd = "BuyElectro", name = "Electro"},
        {cmd = "BuyDeathStep", name = "Death Step"},
        {cmd = "BuySharkmanKarate", name = "Sharkman Karate"},
        {cmd = "BuyElectricClaw", name = "Electric Claw"},
        {cmd = "BuyDragonTalon", name = "Dragon Talon"},
        {cmd = "BuySuperHuman", name = "Superhuman"},
        {cmd = "BuyGodhuman", name = "Godhuman"},
        {cmd = "BuySanguineArt", name = "Sanguine Art"}
    }
    for _, melee in ipairs(checks) do
        local success, result = pcall(function()
            return ReplicatedStorage.Remotes.CommF_:InvokeServer(melee.cmd, true)
        end)
        if success and (result == 1 or result == 2) then
            table.insert(meleeList, melee.name)
        end
        task.wait(0.1)
    end
    -- Dragon Claw check
    local s1, r1 = pcall(function()
        return ReplicatedStorage.Remotes.CommF_:InvokeServer("BlackbeardReward","DragonClaw","1")
    end)
    local s2, r2 = pcall(function()
        return ReplicatedStorage.Remotes.CommF_:InvokeServer("BlackbeardReward","DragonClaw","2")
    end)
    if (s1 and (r1 == 1 or r1 == 2)) or (s2 and (r2 == 1 or r2 == 2)) then
        table.insert(meleeList, "Dragon Breath")
    end
    if #meleeList == 0 then return "None" end
    return table.concat(meleeList, ",\n")
end

-- Webhook function
local function SendWebhook(status)
    if not getgenv().Settings.Webhook.Enabled then return end
    local ping = ""
    local mode = getgenv().Settings.Webhook.PingMode
    local id = getgenv().Settings.Webhook.PingId
    if mode == "Everyone" then ping = "@everyone"
    elseif mode == "Here" then ping = "@here"
    elseif mode == "User" and id ~= "" then ping = "<@" .. id .. ">"
    elseif mode == "Role" and id ~= "" then ping = "<@&" .. id .. ">" end

    local race, rv = GetRaceVersion()
    local data = {
        ["content"] = ping,
        ["embeds"] = {{
            ["title"] = "cookid hub Notification",
            ["username"] = "cookid hub",
            ["avatar_url"] = "https://i.imgur.com/ezB0Y2J.png",
            ["color"] = 0xFF0000,
            ["fields"] = {
                {["name"] = "**Status Farm**", ["value"] = "```\n" .. (status or "None") .. "\n```", ["inline"] = false},
                {["name"] = "**Main Status**", ["value"] = "```\nUsername : " .. player.Name .. "\nLevel : " .. player.Data.Level.Value .. "\nRace : " .. race .. " [V" .. rv .. "]\nFruit : " .. GetFruitInfo() .. "\n```", ["inline"] = false},
                {["name"] = "**Fruit Collected**", ["value"] = "```\n" .. (#fruit_collected > 0 and table.concat(fruit_collected, ",\n") or "None") .. "\n```", ["inline"] = true},
                {["name"] = "**Melee**", ["value"] = "```\n" .. GetOwnedMelee() .. "\n```", ["inline"] = true},
                {["name"] = "**Inventory**", ["value"] = "```\n" .. GetInventoryItems() .. "\n```", ["inline"] = false}
            },
            ["footer"] = {["text"] = "discord.gg/rEFPtrM89"},
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    local success, encoded = pcall(function() return HttpService:JSONEncode(data) end)
    if not success then return end
    local request = syn and syn.request or http_request or request or HttpPost
    if request then
        pcall(function()
            request({
                Url = getgenv().Settings.Webhook.Url,
                Body = encoded,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"}
            })
        end)
    end
end

