-- Função de teleporte (tween)
local function TweenTo(cframe)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local distance = (cframe.Position - hrp.Position).Magnitude
    local speed = distance < 100 and 50 or distance < 400 and 400 or distance < 1000 and 300 or distance < 1500 and 260 or 300
    local tween = TweenService:Create(hrp, TweenInfo.new(distance/speed, Enum.EasingStyle.Linear), {CFrame = cframe})
    tween:Play()
    tween.Completed:Wait()
end

